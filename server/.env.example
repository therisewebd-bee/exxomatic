# ─── Database (Supabase / Aiven PostgreSQL) ────────────────
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# ─── Application ──────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
PORT=5001
TCP_PORT=5000

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_256_bit_secret

# ─── Frontend (for CORS allowlist) ────────────────────────
FRONTEND_URL=https://your-frontend-domain.netlify.app

# ─── Cloudflare Email Worker (geofence breach alerts) ─────
EMAIL_WORKER_URL=https://your-email-worker.workers.dev
