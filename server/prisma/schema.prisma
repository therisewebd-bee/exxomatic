// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions", "driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model VehicleInfo {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  imei         String   @unique @db.VarChar(25)
  vechicleNumb String   @unique @db.VarChar(25)
  customerId   String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer    User                  @relation(fields: [customerId], references: [id])
  locations   LocationLog[]
  compliances VehicleCompliance[]
  geofences   VehiclesOnGeofences[] @relation("VehicleToJoin")

  @@index([imei])
  @@index([vechicleNumb])
  @@index([customerId])
}

model LocationLog {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  imei String @db.VarChar(25) //FK to vechicleInfo

  //position
  lat      Decimal
  lng      Decimal
  altitude Decimal?

  //motion
  speed   Decimal?
  heading Decimal?

  //Device state
  ignition       Boolean  @default(false)
  timestamp      DateTime
  createdAt      DateTime @default(now())

  // ── $SLU Hardware Diagnostics (typed columns) ──────────
  odometer            Float?   // #ODOD# — km reading from ECU
  engine              Boolean? // #ENG#  — engine ON/OFF
  rpm                 Int?     // #RPM#  — engine revolutions
  batteryVoltage      Float?   // #VBAT# — internal battery (V)
  inputVoltage        Float?   // #VIN#  — vehicle battery (V)
  batteryHealth       Int?     // #BATH# — battery health (%)
  batteryCharge       Int?     // #BATC# — battery charge (%)
  temperature         Float?   // #TVI#  — temperature (°C)
  gpsFix              Int?     // #FIX#  — GPS fix type (2D/3D)
  digitalInput1       Boolean? // #IN1#
  digitalInput2       Boolean? // #IN2#
  digitalOutput1      Boolean? // #OUT1#
  totalEngineDuration Int?     // #TDUR# — total engine seconds
  messageSerial       Int?     // Hardware message sequence number
  eventId             String?  @db.VarChar(10) // IoT Event ID (EID)
  rawPacket           String?  @db.Text        // Full unparsed $SLU string

  vehicle VehicleInfo @relation(fields: [imei], references: [imei])

  @@index([imei, timestamp])
  @@index([timestamp])
}

model User {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String        @db.VarChar(50)
  email        String        @unique @db.VarChar(100)
  password     String        @db.VarChar(80)
  role         userRole      @default(Customer)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  vehicleInfos VehicleInfo[]
  geofences    Geofence[]
}

model Geofence {
  id         String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String                   @db.VarChar(50)
  zone       Unsupported("geometry")?
  zoneHash   String?                  @unique @db.VarChar(32)
  isActive   Boolean                  @default(true)
  customerId String?                  @db.Uuid
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  customer   User?                    @relation(fields: [customerId], references: [id])
  vehicles   VehiclesOnGeofences[]    @relation("GeofenceToJoin")

  @@index([zoneHash])
  @@index([customerId])
}

model VehiclesOnGeofences {
  vehicleId  String      @db.Uuid
  geofenceId String      @db.Uuid
  vehicle    VehicleInfo @relation("VehicleToJoin", fields: [vehicleId], references: [id], onDelete: Cascade)
  geofence   Geofence    @relation("GeofenceToJoin", fields: [geofenceId], references: [id], onDelete: Cascade)
  assignedAt DateTime    @default(now())

  @@id([vehicleId, geofenceId])
  @@index([geofenceId])
  @@index([vehicleId])
}

model VehicleCompliance {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicleId String @db.Uuid

  // Fuel entry
  fuelQuantity Decimal // in liters
  fuelRate     Decimal // fetched from govt API at time of entry
  totalCost    Decimal // fuelQuantity * fuelRate — calculated and stored

  // Location where fuel was filled
  filledLat     Decimal?
  filledLng     Decimal?
  filledAddress String?  @db.VarChar(255)

  // Who filled it
  filledBy String @db.VarChar(100)

  // Receipt upload — store file path/URL (S3 or local)
  receiptUrl String? @db.VarChar(500)

  filledAt  DateTime
  createdAt DateTime @default(now())

  vehicle VehicleInfo @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId, filledAt])
  @@index([filledAt])
}

enum userRole {
  Admin
  Customer
}
