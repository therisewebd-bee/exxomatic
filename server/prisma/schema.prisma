// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"

  // preview features to enable if not on v4:
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
}

model VehicleInfo {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  imei         String   @unique @db.VarChar(25)
  vechicleNumb String   @unique @db.VarChar(25)
  customerId   String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer    User                  @relation(fields: [customerId], references: [id])
  locations   LocationLog[]
  compliances VehicleCompliance[]
  geofences   VehiclesOnGeofences[] @relation("VehicleToJoin")

  @@index([imei])
  @@index([vechicleNumb])
  @@index([customerId])
}

model LocationLog {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  imei String @db.VarChar(25) //FK to vechicleInfo

  //position
  lat      Decimal
  lng      Decimal
  altitude Decimal?

  //motion
  speed   Decimal?
  heading Decimal?

  //Device state
  batteryVoltage Float?
  ignition       Boolean  @default(false)
  timestamp      DateTime
  createdAt      DateTime @default(now())

  vehicle VehicleInfo @relation(fields: [imei], references: [imei])

  @@index([imei, timestamp])
  @@index([timestamp])
}

model User {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String        @db.VarChar(50)
  email        String        @unique @db.VarChar(100)
  password     String        @db.VarChar(80)
  role         userRole      @default(Customer)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  vehicleInfos VehicleInfo[]
}

model Geofence {
  id        String                                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String                                      @db.VarChar(50)
  zone      Unsupported("public.geometry(Point,4326)")?
  zoneHash  String?                                     @unique @db.VarChar(32)
  isActive  Boolean                                     @default(true)
  createdAt DateTime                                    @default(now())
  updatedAt DateTime                                    @updatedAt
  vehicles  VehiclesOnGeofences[]                       @relation("GeofenceToJoin")

  @@index([zoneHash])
}

model VehiclesOnGeofences {
  vehicleId  String      @db.Uuid
  geofenceId String      @db.Uuid
  vehicle    VehicleInfo @relation("VehicleToJoin", fields: [vehicleId], references: [id])
  geofence   Geofence    @relation("GeofenceToJoin", fields: [geofenceId], references: [id])
  assignedAt DateTime    @default(now())

  @@id([vehicleId, geofenceId])
}

model VehicleCompliance {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicleId String @db.Uuid

  // Fuel entry
  fuelQuantity Decimal // in liters
  fuelRate     Decimal // fetched from govt API at time of entry
  totalCost    Decimal // fuelQuantity * fuelRate — calculated and stored

  // Location where fuel was filled
  filledLat     Decimal?
  filledLng     Decimal?
  filledAddress String?  @db.VarChar(255)

  // Who filled it
  filledBy String @db.VarChar(100)

  // Receipt upload — store file path/URL (S3 or local)
  receiptUrl String? @db.VarChar(500)

  filledAt  DateTime
  createdAt DateTime @default(now())

  vehicle VehicleInfo @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId, filledAt])
  @@index([filledAt])
}

enum userRole {
  Admin
  Customer
}
